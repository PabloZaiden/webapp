{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["bun"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@pablozaiden/webapp/server": ["./src/server/index.ts"],
      "@pablozaiden/webapp/web": ["./src/web/index.ts"],
      "@pablozaiden/webapp/contracts": ["./src/contracts/index.ts"],
      "@pablozaiden/webapp/cli": ["./src/cli/index.ts"],
      "@pablozaiden/webapp/build": ["./src/build/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "tests/**/*.ts"
  ]
}
